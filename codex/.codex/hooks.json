{
  "description": "harness-mem: Codex CLI hooks (experimental, v0.116.0+)",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash __HARNESS_ROOT__/scripts/hook-handlers/codex-session-start.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash __HARNESS_ROOT__/scripts/hook-handlers/codex-user-prompt.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash __HARNESS_ROOT__/scripts/hook-handlers/codex-session-stop.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
