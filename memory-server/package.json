{
  "name": "@claude-code-harness/memory-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "benchmark": "bun run src/benchmark/run-ci.ts",
    "benchmark:counterfactual": "bun run src/benchmark/inject-counterfactual-eval.ts",
    "benchmark:tune-adaptive": "bun run src/benchmark/adaptive-tuning.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "bash ../scripts/run-bun-test-safe.sh tests/*.test.ts && bash ../scripts/run-bun-test-batches.sh tests/unit tests/core-split tests/integration tests/benchmark tests/performance",
    "test:unit": "bash ../scripts/run-bun-test-safe.sh tests/unit",
    "test:integration": "bash ../scripts/run-bun-test-safe.sh tests/integration",
    "test:benchmark": "bash ../scripts/run-bun-test-safe.sh tests/benchmark"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.19.15",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@huggingface/transformers": "3.8.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "tesseract.js": "^7.0.0"
  }
}
