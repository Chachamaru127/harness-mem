{
  "name": "@chachamaru127/harness-mem",
  "version": "0.8.5",
  "description": "Memory bridge for Claude Code and Codex — local-first, zero-cost coding memory runtime",
  "homepage": "https://github.com/Chachamaru127/harness-mem",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Chachamaru127/harness-mem.git"
  },
  "bugs": {
    "url": "https://github.com/Chachamaru127/harness-mem/issues"
  },
  "license": "BUSL-1.1",
  "type": "commonjs",
  "bin": {
    "harness-mem": "scripts/harness-mem",
    "harness-memd": "scripts/harness-memd",
    "harness-mem-client": "scripts/harness-mem-client.sh"
  },
  "files": [
    "README.md",
    "CHANGELOG.md",
    "docs/harness-mem-setup.md",
    "docs/release-process.md",
    "scripts/",
    "tests/test-memory-search-quality.sh",
    "memory-server/src/",
    "memory-server/tests/",
    "memory-server/package.json",
    "memory-server/tsconfig.json",
    "mcp-server/dist/",
    "mcp-server/src/",
    "mcp-server/tsconfig.json",
    "mcp-server/package.json",
    "hooks/",
    "codex/",
    "opencode/plugins/",
    "harness-mem-ui/src/",
    "harness-mem-ui/package.json",
    ".cursor/hooks.json.example",
    ".cursor/hooks/",
    "gemini/"
  ],
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "sharp": "0.34.5"
  },
  "optionalDependencies": {
    "@img/sharp-libvips-darwin-arm64": "1.2.4"
  },
  "devDependencies": {
    "pg": "^8.20.0"
  },
  "scripts": {
    "test": "(cd memory-server && bun run test) && bash scripts/run-bun-test-batches.sh tests sdk/tests mcp-server/tests",
    "test:ui": "cd harness-mem-ui && bunx vitest",
    "test:e2e": "cd harness-mem-ui && bunx playwright test"
