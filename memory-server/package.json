{
  "name": "@claude-code-harness/memory-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test tests/*.test.ts && bun test tests/unit && bun test tests/core-split && bun test tests/integration && bun test tests/benchmark tests/performance",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:benchmark": "bun test tests/benchmark"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.19.15",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "tesseract.js": "^7.0.0"
  }
}
