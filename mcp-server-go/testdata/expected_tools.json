            "cpp"
          ],
          "type": "string"
        },
        "path": {
          "description": "Search path (default: current directory)",
          "type": "string"
        },
        "pattern": {
          "description": "AST pattern using ast-grep syntax. Use $ for single node, $$$ for multiple nodes.",
          "type": "string"
        }
