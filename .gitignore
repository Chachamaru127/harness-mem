# OS
.DS_Store

# Local tool/runtime state
.external_refs/
.firecrawl/
.harness-mem/
.playwright-mcp/
.opencode/
.tmp/
.claude/
.claude/state/
.claude/sessions/
.claude/logs/
tests/benchmarks/output/
**/.claude/state/
**/.claude/sessions/
**/.claude/logs/

# Build/dependency artifacts
**/node_modules/
**/dist/
# Allow mcp-server/dist/ so the plugin works on fresh clone
!mcp-server/dist/
!mcp-server/dist/**

# Local Go build output (release binaries are built in CI; committed copies live in /bin)
mcp-server-go/bin/

# Local Codex runtime files
.codex/config.toml
.codex/history.jsonl
.codex/history*.jsonl
/.codex/skills/release-mem/
/.codex/skills/upstream-compat-watch/

# Local-only agent instructions
AGENTS.override.md

# Local launch marketing drafts
Plans.md.bak.*
Plans-launch.md
launch/

# Local Cursor runtime wiring (generated by scripts/harness-mem setup)
.cursor/hooks.json

# Codex loop wrapper (provisioned per-project by claude-code-harness scaffolder,
# not a harness-mem product feature — see Chachamaru127/claude-code-harness#98)
scripts/codex-loop.sh
scripts/codex-loop-validate-noop.sh

# npm credentials
.npmrc

# Local secrets / MCP config
.env
.env.*
env.local
.mcp.json

# Python cache artifacts
**/__pycache__/
**/*.pyc

# Binary data
*.traineddata

# Test artifacts
test-ruri-v3/

# Benchmark freeze artifacts (generated locally)
memory-server/src/benchmark/results/freeze-run-*.log
memory-server/src/benchmark/results/freeze-run-*.tsv
memory-server/src/benchmark/results/ci-run-manifest-history.jsonl
memory-server/src/benchmark/results/retrospective-*.json
memory-server/src/benchmark/results/retrospective-*.jsonl

# mcp-server-go cross-build artifacts (tracked `bin/harness-mcp-server` is preserved)
bin/harness-mcp-darwin-*
bin/harness-mcp-linux-*
bin/harness-mcp-windows-*
mcp-server-go/bin/
