  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "claude-code",
    "codex",
    "memory",
    "harness",
    "local-first",
    "mcp",
    "cursor",
    "gemini-cli",
    "gemini",
    "opencode"
  ],
  "trustedDependencies": [
    "onnxruntime-node",
    "protobufjs"
  ]
